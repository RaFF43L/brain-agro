{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "src/.*\\.integration\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(jose)/)"
  ],
  "testTimeout": 30000
}
