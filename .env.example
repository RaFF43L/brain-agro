PORT=
NODE_ENV=

SWAGGER_PASSWORD=

# Auth
# Set to "true" to enable Cognito JWT authentication.
# Leave empty or set to any other value to run without authentication (useful for local dev).
AUTH_ENABLED=

# PostgreSQL
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

# AWS (required only when AUTH_ENABLED=true)
AWS_REGION=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_USER_POOL_ID=
AWS_ACCESS_KEY_ID_COGNITO=
AWS_SECRET_ACCESS_KEY_COGNITO=